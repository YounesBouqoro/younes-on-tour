rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tours/{id} {
      allow read: if resource.data.published == true
        || (request.auth != null && request.auth.token.email == "DEINE_EMAIL@BEISPIEL.DE");
      allow write: if request.auth != null
        && request.auth.token.email == "DEINE_EMAIL@BEISPIEL.DE";
    }
    match /milestones/{id} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "DEINE_EMAIL@BEISPIEL.DE";
    }
  }
}